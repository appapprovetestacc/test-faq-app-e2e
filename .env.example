# Local-development env vars. AppApprove injects production secrets at
# deploy time - do not paste production credentials here.

# Shopify partner credentials (from Partner Dashboard > Apps > <app>).
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products
SHOPIFY_APP_URL=http://localhost:8788

# Phase 3.9 A — support + legal page contacts. Surfaced through the
# /support, /privacy, /uninstall, and /data-retention routes. Reviewers
# expect monitored inboxes; placeholders fail the trust-asset checklist.
SUPPORT_EMAIL=support@example.com
EMERGENCY_CONTACT_EMAIL=emergency@example.com
DPA_CONTACT_NAME=Privacy Lead
DPA_CONTACT_EMAIL=privacy@example.com
DATA_DELETION_INSTRUCTIONS_URL=https://example.com/data-deletion

# Phase 3.9 B — optional public-status link to the AppApprove monitor
# ingest endpoint. Leave empty unless you've set up a custom status
# page that consumes the ingest stream.
STATUS_INGEST_URL=
